# =============================================================================
# HomeFlix Configuration
# =============================================================================
# Copy this file to .env and fill in your values

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME=HomeFlix
APP_ENV=development  # development, staging, production
DEBUG=true
LOG_LEVEL=DEBUG  # DEBUG, INFO, WARNING, ERROR

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# SQLite (development)
DATABASE_URL=sqlite+aiosqlite:///./homeflix.db

# PostgreSQL (production)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/homeflix

# -----------------------------------------------------------------------------
# Media Directories
# -----------------------------------------------------------------------------
# Comma-separated list of directories to scan for media files
MEDIA_DIRECTORIES=/path/to/movies,/path/to/series

# Where to store generated thumbnails
THUMBNAILS_DIRECTORY=./thumbnails

# -----------------------------------------------------------------------------
# External APIs
# -----------------------------------------------------------------------------
# TMDB - The Movie Database (https://www.themoviedb.org/settings/api)
TMDB_API_KEY=your_tmdb_api_key_here
TMDB_BASE_URL=https://api.themoviedb.org/3

# OMDb - Open Movie Database (https://www.omdbapi.com/apikey.aspx)
# Optional: used as fallback when TMDB doesn't have data
OMDB_API_KEY=your_omdb_api_key_here

# -----------------------------------------------------------------------------
# Internationalization
# -----------------------------------------------------------------------------
DEFAULT_LOCALE=en
SUPPORTED_LOCALES=en,pt-BR

# -----------------------------------------------------------------------------
# Security (for future use)
# -----------------------------------------------------------------------------
# SECRET_KEY=your-secret-key-here-change-in-production
# ACCESS_TOKEN_EXPIRE_MINUTES=30
